{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
        "UseUtcTimestamp": true
      }
    }
  },
  "Database": {
    "ApplyMigrations": false
  },
  "DataProtection": {
    "KeysPath": "/data/keys"
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "personal-service"
  }
}

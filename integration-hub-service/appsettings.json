{
  "Auth": {
    "Issuer": "nucleus-auth",
    "Audience": "nucleus-api",
    "SigningKey": "CHANGE_ME_SUPER_SECRET_KEY"
  },
  "ConnectionStrings": {
    "IntegrationHubDb": "Data Source=integration-hub.db"
  },
  "Scheduler": {
    "Enabled": true,
    "IntervalSeconds": 60,
    "MaxRetries": 3
  },
  "Secrets": {
    "SecretsFile": "secrets.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
